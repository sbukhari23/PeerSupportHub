PORT=5000
NODE_ENV=development

MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/peersupporthub?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate random string: Run this command in terminal:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Or use: https://randomkeygen.com/ (choose "CodeIgniter Encryption Keys")
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-long-random-string

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Your frontend URL (for CORS and email verification links)
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ============================================
# EMAIL CONFIGURATION (OPTIONAL - Currently Disabled)
# ============================================
# Email features are currently commented out in code
# Uncomment in routes/userRoutes.js when ready to use
# 
# Option 1: Gmail (Free, 500 emails/day)
# Get from: https://myaccount.google.com/apppasswords
# Steps:
# 1. Enable 2-Step Verification in your Google Account
# 2. Go to App Passwords: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device
# 4. Use generated 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=noreply@peersupporthub.com

