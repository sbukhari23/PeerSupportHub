# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Get from: https://cloud.mongodb.com/
# Steps:
# 1. Create account at MongoDB Atlas (https://cloud.mongodb.com/)
# 2. Create a cluster (Free M0 tier available)
# 3. Click "Connect" → "Connect your application"
# 4. Copy the connection string and replace <password> with your database password
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/peersupporthub?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate random string: Run this command in terminal:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Or use: https://randomkeygen.com/ (choose "CodeIgniter Encryption Keys")
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-long-random-string

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Your frontend URL (for CORS and email verification links)
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ============================================
# EMAIL CONFIGURATION (OPTIONAL - Currently Disabled)
# ============================================
# Email features are currently commented out in code
# Uncomment in routes/userRoutes.js when ready to use
# 
# Option 1: Gmail (Free, 500 emails/day)
# Get from: https://myaccount.google.com/apppasswords
# Steps:
# 1. Enable 2-Step Verification in your Google Account
# 2. Go to App Passwords: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device
# 4. Use generated 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=noreply@peersupporthub.com

# Option 2: SendGrid (Free, 100 emails/day)
# Get from: https://sendgrid.com/
# Steps:
# 1. Create account at SendGrid
# 2. Create API Key in Settings → API Keys
# 3. Use these settings:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Option 3: Ethereal (Development/Testing only - Fake SMTP)
# Get from: https://ethereal.email/create
# Steps:
# 1. Visit https://ethereal.email/create
# 2. Copy username and password
# 3. Emails won't actually send, you get preview URLs in console
ETHEREAL_USER=your-ethereal-user@ethereal.email
ETHEREAL_PASS=your-ethereal-password

# ============================================
# RATE LIMITING
# ============================================
# Set to true to disable rate limiting (useful for testing)
# Set to false in production
RATE_LIMIT_DISABLED=false
